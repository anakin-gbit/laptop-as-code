#cloud-config
autoinstall:
  version: 1

  keyboard:
    layout: gb

  # REMOVED: The network section. 
  # This stops Subiquity from trying to run 'netplan apply'.

  identity:
    hostname: hermit
    username: anakin
    password: "$6$nqtWxwBprqsWYxsX$o2N.7k/Cg7DOA9GjYOJcRuje/oT2KyWuC79oZBCYh.Gf.3sr1aw.Cvnf3tS/2tAwrS5/9ByP2.S3q38n1nk96/"

  ssh:
    install-server: true
    allow-pw: true

  storage:
    layout:
      name: direct

  # THIS is the part that actually writes the file to the disk
  late-commands:
    # ITEM 1: Write the file
    - |
      cat <<EOF > /target/etc/netplan/00-installer-config.yaml
      network:
        version: 2
        renderer: networkd
        ethernets:
          id0:
            match:
              name: "e*"
            dhcp4: true
      EOF

    # ITEM 2: Run the network commands (Notice the NEW DASH here)
    - |
      curtin in-target -- bash -c "
        # 2. Force Netplan to take over and wake the port
        netplan apply
        
        # 3. Add DNS manually just in case
        echo 'nameserver 8.8.8.8' > /etc/resolv.conf
        
        # 4. Wait for the negotiation
        sleep 10
        
        # 5. Download and Run
        curl -sL https://raw.githubusercontent.com/anakin-gbit/laptop-as-code/main/version1/public-bootstrap.sh -o /usr/local/bin/public-bootstrap.sh
        
        if [ -f /usr/local/bin/public-bootstrap.sh ]; then
          chmod +x /usr/local/bin/public-bootstrap.sh
          /bin/bash /usr/local/bin/public-bootstrap.sh
        fi
        
        # Log status for you to check
        ip addr show > /root/install_network_status.txt
      "
